@model IT6CFirstWebAppCS.Models.SettingsViewModel

<div class="container mt-4">
    <div class="alert alert-info">
        <h3>Selection Received Successfully</h3>
    </div>

    <ul class="list-group shadow-sm">
        <li class="list-group-item">
            <strong>Main Selection:</strong> @Model.SelectedPreference.ToString()
        </li>
        <li class="list-group-item">
            <strong>Main Selection 2:</strong> @Model.SelectedPreference2.ToString()
        </li>
        <li class="list-group-item">
            <strong>Multiple Selections:</strong>
            <div class="mt-2">
                @if (Model.SelectedRoles != null && Model.SelectedRoles.Length > 0)
                {
                    foreach (var role in Model.SelectedRoles)
                    {
                        <span class="badge bg-dark me-1">@role</span>
                    }
                }
                else
                {
                    <span class="text-muted">None</span>
                }
            </div>
        </li>
    </ul>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-primary">Try Again</a>
    </div>
</div>